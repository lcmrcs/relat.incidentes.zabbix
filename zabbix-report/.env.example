# Copie este arquivo para ".env" dentro da pasta zabbix-report.
# Nunca envie o arquivo ".env" real para o GitHub.

# Endpoint JSON-RPC da API do Zabbix.
# Normalmente termina com /api_jsonrpc.php
ZABBIX_URL=https://seu-zabbix.example.com/api_jsonrpc.php

# Token de API criado no Zabbix para leitura dos dados monitorados.
# Cole aqui somente no arquivo ".env" real, nunca neste exemplo.
ZABBIX_TOKEN=cole_seu_token_do_zabbix_aqui
